package transactions;

/**
 * Holds payment-related information for a transaction.
 *
 * IMPORTANT (per project specification):
 * CommonGround does NOT collect, verify, or process real payment credentials.
 * No actual card numbers, bank account numbers, or routing numbers are stored.
 * This class only captures the agreed payment method, the agreed price,
 * and optional contact handle (e.g. Zelle phone number, CashApp $tag).
 *
 * Validation only checks format correctness — NOT authenticity or fund availability.
 */
public class PaymentInfo {

    private PaymentMethod method;
    private double agreedPrice;
    private String paymentHandle; // e.g. phone number for Zelle, $tag for CashApp (optional)

    public PaymentInfo(PaymentMethod method, double agreedPrice, String paymentHandle) {
        this.method = method;
        this.agreedPrice = agreedPrice;
        this.paymentHandle = paymentHandle;
    }

    public PaymentInfo(PaymentMethod method, double agreedPrice) {
        this(method, agreedPrice, "");
    }

    // ─── Getters ─────────────────────────────────────────────────────────────

    public PaymentMethod getMethod() {
        return method;
    }

    public double getAgreedPrice() {
        return agreedPrice;
    }

    public String getPaymentHandle() {
        return paymentHandle;
    }

    // ─── Setters ─────────────────────────────────────────────────────────────

    public void setMethod(PaymentMethod method) {
        this.method = method;
    }

    public void setAgreedPrice(double agreedPrice) {
        this.agreedPrice = agreedPrice;
    }

    public void setPaymentHandle(String paymentHandle) {
        this.paymentHandle = paymentHandle;
    }

    @Override
    public String toString() {
        return "PaymentInfo{method=" + method
                + ", agreedPrice=$" + String.format("%.2f", agreedPrice)
                + ", handle='" + paymentHandle + "'}";
    }
}

