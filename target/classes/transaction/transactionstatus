package transactions;

/**
 * Enum representing all possible states of a transaction.
 * Transactions flow: PENDING -> BUYER_CONFIRMED / SELLER_CONFIRMED -> BOTH_CONFIRMED -> COMPLETED
 * or can be CANCELLED at any point before BOTH_CONFIRMED.
 */
public enum TransactionStatus {
    PENDING,           // Transaction created, awaiting both parties
    BUYER_CONFIRMED,   // Buyer has hit 'confirm'
    SELLER_CONFIRMED,  // Seller has hit 'confirm'
    BOTH_CONFIRMED,    // Both parties confirmed, moving to rating/review screen
    COMPLETED,         // Transaction fully completed (post-rating)
    CANCELLED,         // Transaction was cancelled
    FAILED             // Transaction failed validation or process
}

