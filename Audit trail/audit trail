package com.app.audit;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

public class AuditTrail {

    private final List<AuditRecord> records = new ArrayList<>();
    private final List<TransactionLog> transactionLogs = new ArrayList<>();

    /**
     * Creates and stores a new audit record for the given type and record ID.
     *
     * @param recordType the category of the event (e.g. TRANSACTION, LISTING, NEW_USER)
     * @param recordId   the unique identifier of the entity being recorded
     * @return the newly created AuditRecord
     */
    public AuditRecord createRecord(RecordType recordType, String recordId) {
        AuditRecord record = new AuditRecord(recordId, recordType);
        records.add(record);
        System.out.println("[AuditTrail] Record created: " + record);
        return record;
    }

    /**
     * Logs a transaction event with full context.
     *
     * @param id     the transaction identifier
     * @param time   the timestamp of the event
     * @param client the client (user/session) associated with the transaction
     * @param info   any additional details about the transaction
     * @return the newly created TransactionLog
     */
    public TransactionLog logTransaction(String id, LocalDateTime time, String client, String info) {
        TransactionLog log = new TransactionLog(id, time, client, info);
        transactionLogs.add(log);
        System.out.println("[AuditTrail] Transaction logged: " + log);
        return log;
    }

    /**
     * Returns an unmodifiable view of all audit records.
     */
    public List<AuditRecord> getRecords() {
        return Collections.unmodifiableList(records);
    }

    /**
     * Returns an unmodifiable view of all transaction logs.
     */
    public List<TransactionLog> getTransactionLogs() {
        return Collections.unmodifiableList(transactionLogs);
    }

    /**
     * Returns all audit records that match a specific RecordType.
     *
     * @param type the record type to filter by
     * @return list of matching AuditRecords
     */
    public List<AuditRecord> getRecordsByType(RecordType type) {
        List<AuditRecord> filtered = new ArrayList<>();
        for (AuditRecord record : records) {
            if (record.getRecordType() == type) {
                filtered.add(record);
            }
        }
        return Collections.unmodifiableList(filtered);
    }

    /**
     * Returns the transaction log with the given ID, or null if not found.
     *
     * @param id the transaction ID to look up
     * @return matching TransactionLog or null
     */
    public TransactionLog findTransactionById(String id) {
        for (TransactionLog log : transactionLogs) {
            if (log.getId().equals(id)) {
                return log;
            }
        }
        return null;
    }
}
