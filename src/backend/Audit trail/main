package com.app.audit;

import java.time.LocalDateTime;
import java.util.List;

public class Main {

    public static void main(String[] args) {
        AuditTrail auditTrail = new AuditTrail();

        // --- CreateRecord examples ---
        auditTrail.createRecord(RecordType.NEW_USER, "user-001");
        auditTrail.createRecord(RecordType.LISTING, "listing-042");
        auditTrail.createRecord(RecordType.TRANSACTION, "txn-998");
        auditTrail.createRecord(RecordType.MEETUP, "meetup-17");
        auditTrail.createRecord(RecordType.FEEDBACK, "feedback-305");

        // --- LogTransaction examples ---
        auditTrail.logTransaction(
            "txn-998",
            LocalDateTime.of(2026, 3, 31, 14, 30, 0),
            "client-alice",
            "Purchase of listing-042 for $350"
        );

        auditTrail.logTransaction(
            "txn-999",
            LocalDateTime.now(),
            "client-bob",
            "Payment released after confirmed meetup"
        );

        System.out.println("\n--- All Audit Records ---");
        for (AuditRecord rec : auditTrail.getRecords()) {
            System.out.println(rec);
        }

        System.out.println("\n--- Transaction Records Only ---");
        List<AuditRecord> txnRecords = auditTrail.getRecordsByType(RecordType.TRANSACTION);
        for (AuditRecord rec : txnRecords) {
            System.out.println(rec);
        }

        System.out.println("\n--- All Transaction Logs ---");
        for (TransactionLog log : auditTrail.getTransactionLogs()) {
            System.out.println(log);
        }

        System.out.println("\n--- Lookup by ID ---");
        TransactionLog found = auditTrail.findTransactionById("txn-998");
        System.out.println("Found: " + found);
    }
}
